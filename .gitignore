# Python cache
__pycache__/
*.py[cod]
*$py.class

# Build / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checking / linting
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# IDEs / editors
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs and environment files
*.log
.env

# Local generated outputs
outputs/
results/
tmp/
tmp_*/
*.npz
*.npy
*.jsonl

# Local data
data/raw/
data/interim/
data/processed/

# Keep lightweight reference/documentation files if needed
!data/README.md
!data/benchmark_table.csv

# Keep documentation assets if added later
!docs/assets/
!docs/assets/*.png
!docs/assets/*.svg
!docs/assets/*.pdf